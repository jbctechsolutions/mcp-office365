{
  "name": "@jbctechsolutions/mcp-outlook-mac",
  "version": "0.1.0",
  "description": "MCP server for read-only access to Outlook for Mac's local SQLite database",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mcp-outlook-mac": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "outlook",
    "macos",
    "email",
    "calendar",
    "contacts",
    "model-context-protocol"
  ],
  "author": "JBC Tech Solutions, LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbctechsolutions/outlook-mac-mcp.git"
  },
  "homepage": "https://github.com/jbctechsolutions/outlook-mac-mcp#readme",
  "bugs": {
    "url": "https://github.com/jbctechsolutions/outlook-mac-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@azure/msal-node": "^2.6.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.6.0",
    "isomorphic-fetch": "^3.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@microsoft/microsoft-graph-types": "^2.40.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^8.57.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
